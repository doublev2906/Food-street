# Copy file này -> deploy.config rồi điền thông tin. deploy.config bị .gitignore.

# --- Kết nối SSH tới server ---
SSH_HOST="123.45.67.89"      # IP hoặc domain của server
SSH_USER="pancake"           # user SSH trên server (KHÔNG dùng root)
SSH_PORT="22"

# --- Vị trí code đã clone trên server ---
APP_DIR="/opt/food_street"

# --- Git: remote chung mà CẢ máy dev lẫn server đều kéo được (vd GitHub private) ---
GIT_REMOTE="origin"
BRANCH="master"

# --- (tuỳ chọn) khớp với cấu hình trên server ---
SERVICE="food_street"                 # tên systemd service
REMOTE_ENV_FILE="/etc/food_street/env"
PHX_HOST="ten-mien-cua-ban.com"       # chỉ dùng để in URL sau khi deploy
