# Copy file này -> .env (cùng thư mục docker-compose.prod.yml). KHÔNG commit .env.
# docker compose tự nạp .env để thay ${...} trong compose file.

# Tên miền HOẶC địa chỉ IP của server.
#  - Có domain: PHX_HOST=ten-mien.com         + để CADDY_EXTRA_TLS trống (HTTPS Let's Encrypt thật)
#  - Chỉ có IP: PHX_HOST=123.45.67.89          + CADDY_EXTRA_TLS="tls internal" (HTTPS tự ký)
PHX_HOST=10.1.12.216
CADDY_EXTRA_TLS=tls internal

# Sinh bằng: cd backend && mix phx.gen.secret  (hoặc: openssl rand -base64 64)
SECRET_KEY_BASE=thay-bang-chuoi-bi-mat-dai

# Thông tin PostgreSQL (chạy trong container db)
DB_USER=food_street
DB_PASS=doi-mat-khau-that-manh
DB_NAME=food_street_prod

# Cổng web (FE) publish ra host. Mặc định 80/443.
# Đổi nếu cổng bị chiếm, vd HTTPS_PORT=8443 -> truy cập https://<ip>:8443
HTTP_PORT=80
HTTPS_PORT=443
