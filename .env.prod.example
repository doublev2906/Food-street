# Copy file này -> .env (cùng thư mục docker-compose.prod.yml). KHÔNG commit .env.
# docker compose tự nạp .env để thay ${...} trong compose file.

# Tên miền của server (chỉ dùng để backend in URL). TLS do nginx phía trước lo
# (cert *.pancake.vn), Caddy trong container chỉ chạy HTTP thuần ở WEB_PORT.
# Luồng: https://dev.pancake.vn:3200 (nginx, TLS) -> http://<server>:3200 (Caddy).
PHX_HOST=dev.pancake.vn

# Cổng HTTP nội bộ FE publish ra host (để nginx ngoài proxy vào).
WEB_PORT=3200

# Sinh bằng: cd backend && mix phx.gen.secret  (hoặc: openssl rand -base64 64)
SECRET_KEY_BASE=thay-bang-chuoi-bi-mat-dai

# Thông tin PostgreSQL (chạy trong container db)
DB_USER=food_street
DB_PASS=doi-mat-khau-that-manh
DB_NAME=food_street_prod

# Cổng web (FE) publish ra host. Mặc định 80/443.
# Đổi nếu cổng bị chiếm, vd HTTPS_PORT=8443 -> truy cập https://<ip>:8443
HTTP_PORT=80
HTTPS_PORT=443

# Secret bảo vệ webhook Pancake Page (nhà bán trả lời -> relay về Panchat).
# Sinh bằng: openssl rand -hex 32
# URL webhook đăng ký với Pancake: https://<PHX_HOST>/api/webhooks/pancake/<secret này>
PANCAKE_WEBHOOK_SECRET=thay-bang-chuoi-bi-mat-ngau-nhien
