# Dockerfile cho môi trường DEV (code reload, mount source).
# Khớp phiên bản với máy local: Elixir 1.18 / OTP 27.
FROM hexpm/elixir:1.18.3-erlang-27.3-debian-bookworm-20250317-slim

# Thư viện cần để build (bcrypt_elixir cần build C NIF) + tiện ích chờ DB.
RUN apt-get update -y && \
    apt-get install -y build-essential git inotify-tools postgresql-client && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

RUN mix local.hex --force && mix local.rebar --force

WORKDIR /app

# Cài deps trước (tận dụng cache layer). Source thực tế sẽ được mount qua volume.
COPY mix.exs mix.lock ./
RUN mix deps.get
RUN mix deps.compile

COPY . .

ENV MIX_ENV=dev

EXPOSE 4000

COPY entrypoint.dev.sh /entrypoint.dev.sh
RUN chmod +x /entrypoint.dev.sh

ENTRYPOINT ["/entrypoint.dev.sh"]
CMD ["mix", "phx.server"]
